{
    "name": "giorgiosironi/eris",
    "description": "PHP library for property-based testing. Integrates with PHPUnit.",
    "authors": [
        {
            "name": "Giorgio Sironi",
            "email": "info@giorgiosironi.com"
        },
        {
            "name": "Mirko Bonadei",
            "email": "mirko.bonadei@gmail.com"
        },
        {
            "name": "Gabriele Lana",
            "email": "gabriele.lana@gmail.com"
        }
    ],
    "license": "MIT",
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0.4 || ^11.0 || ^12.0 || ^13.0",
        "sebastian/comparator": ">=2.1.3",
        "friendsofphp/php-cs-fixer": "^3.0",
        "ilario-pierbattista/reverse-regex": "0.5.0",
        "phpstan/phpstan": "^2.0",
        "psalm/phar": "^5.4",
        "rector/rector": "^2.0"
    },
    "suggest":
    {
        "phpunit/phpunit": "Standard way to run generated test cases",
        "ilario-pierbattista/reverse-regex": "0.5.0 for the regex() Generator"
    },
    "autoload": {
        "psr-4": {
            "Eris\\" : "src/"
        },
        "files": [
            "src/Generator/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Eris\\": "test/"
        }
    },
    "scripts": {
        "cs": [
            "composer validate --no-check-lock",
            "composer update",
            "vendor/bin/php-cs-fixer fix --verbose --diff"
        ],
        "test": [
            "composer validate --no-check-lock",
            "composer update",
            "vendor/bin/phpunit test"
        ],
        "static": [
            "vendor/bin/phpstan --memory-limit=512M",
            "vendor/bin/psalm.phar"
        ],
        "phpstan-baseline": [
            "vendor/bin/phpstan analyse -c phpstan.neon --generate-baseline --memory-limit=512M"
        ],
        "psalm-baseline": [
            "vendor/bin/psalm.phar --set-baseline=psalm-baseline.xml"
        ],
        "rector": [
            "vendor/bin/rector"
        ]
    }
}
